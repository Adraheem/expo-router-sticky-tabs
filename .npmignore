# Publishing is driven by the "files" allowlist in package.json (build, src,
# LICENSE, README.md). This file just keeps dev cruft out of any included dirs.
__mocks__
__tests__
*.test.ts
*.test.tsx
*.tsbuildinfo
/*.tgz

# Local test application
example/

# Internal documentation and tools
docs/
internal/

# Local configurations and hidden tools
.claude/
.husky/
.prettierrc
commitlint.config.js
eslint.config.cjs
jest.setup.js
